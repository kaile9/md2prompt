    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.42.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
